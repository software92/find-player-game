{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "skipLibCheck": true,
    "rootDir": "src",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      // "shared/*": ["../shared/*"]
      "shared/*": ["src/shared/*"]
    }
  },
  "compileOnSave": true,
  // "include": ["src/**/*", "../shared/*"]
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib"]
}
